{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#2A2A2A",
          "foreground": "#CCCCCC",
          "style": "powerline",
          "powerline_symbol": "",
          "template": " {{ .Path }} ",
          "type": "path",
          "options": {
            "style": "full"
          }
        },
        {
          "background": "#444444",
          "foreground": "#EEEEEE",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  {{ .HEAD }} ",
          "type": "git",
          "options": {
            "fetch_status": true,
            "branch_icon": ""
          }
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "version": 4
}
